altura = float(input("qual sua altura? "))
    
def calcular_imc (peso, altura):
    imc = peso / (altura ** 2)
    return imc
    
imc = calcular_imc (peso, altura)
print (imc)

def classificar_imc (imc):
    if imc <18.5:
        return ("peso baixo (menor que 18.5)")
    elif imc >= 18.6 <=24.9:
        return ("peso normal (maior ou igual a 18.6 e menor ou igual a 24.9)")
    elif imc >=25.0 <=29.9:
        return ("sobrepeso (maior ou igual a 25.0 e menor ou igual a 29.9)")
    elif imc >=30.0:
        return ("obeso (maior que 30.0)")
        
